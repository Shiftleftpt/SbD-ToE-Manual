# Makefile — Geração do manual SbD-ToE em LaTeX + PDF
DOCS_SRC     ?= ../doc_manual_src/docs/sbd-toe
OUT_DIR      ?= ../BOOK/pdf

TEX_NAME     := manual-sbd-toe
TEX_OUT      := $(OUT_DIR)/$(TEX_NAME).tex
PDF_OUT      := $(OUT_DIR)/$(TEX_NAME).pdf
BOOK_YML     := book.yml

SCRIPT_TEX   := parse_book_yaml.py
SCRIPT_EIS   := parse_book_yaml_eisvogel.py
PDF_EIS      := $(OUT_DIR)/manual-sbd-toe.pdf
MD_EIS       := $(OUT_DIR)/manual-sbd-toe.md

.PHONY: all clean tex pdf index full eisvogel

all: pdf

# --- Pandoc com Eisvogel ---
eisvogel: $(SCRIPT_EIS) $(BOOK_YML)
	@echo "[INFO] A gerar PDF com Eisvogel (estilo pandoc)"
	python3 $(SCRIPT_EIS)

# --- Geração do .tex (via Pandoc tradicional)
tex: $(TEX_OUT)

$(TEX_OUT): $(SCRIPT_TEX) $(BOOK_YML)
	@echo "[INFO] A gerar LaTeX a partir de $(BOOK_YML)"
	mkdir -p $(OUT_DIR)
	python3 $(SCRIPT_TEX)

# --- PDF tradicional com LaTeX
pdf: tex
	@echo "[INFO] A gerar PDF com xelatex"
	cd $(OUT_DIR) && xelatex -interaction=nonstopmode $(TEX_NAME).tex > build.log
	cd $(OUT_DIR) && xelatex -interaction=nonstopmode $(TEX_NAME).tex >> build.log

# --- Compilação com índice analítico
index: tex
	@echo "[INFO] A compilar com makeindex"
	cd $(OUT_DIR) && xelatex -interaction=nonstopmode $(TEX_NAME).tex > build.log
	cd $(OUT_DIR) && makeindex $(TEX_NAME).idx
	cd $(OUT_DIR) && xelatex -interaction=nonstopmode $(TEX_NAME).tex >> build.log

# --- Build completo com índice
full:
	make clean
	make index

# --- Limpeza de artefactos
clean:
	@echo "[INFO] A limpar ficheiros gerados"
	rm -rf \
	  $(OUT_DIR)/*.pdf \
	  $(OUT_DIR)/*.aux \
	  $(OUT_DIR)/*.log \
	  $(OUT_DIR)/*.out \
	  $(OUT_DIR)/*.toc \
	  $(OUT_DIR)/*.idx \
	  $(OUT_DIR)/*.ind \
	  $(OUT_DIR)/*.ilg \
	  $(OUT_DIR)/*.tex \
	  $(OUT_DIR)/*.md
